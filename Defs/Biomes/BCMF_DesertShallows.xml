<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<!--
		Wrapper biome: bakes the Biomes Caverns "Desert Shallows" BiomeVariantDef content
		(BMT_DesertShallows, "inside"/roofed-cave layer) into a force-assignable BiomeDef so it
		can be set on a Multifloors basement pocket map via C#. Carries the BiomesMap cavern
		extension so GenStep_RocksFromGrid auto-substitutes the cavern carve. Never generates
		naturally on the world map.
	-->
	<BiomeDef>
		<defName>BCMF_DesertShallows</defName>
		<label>desert shallows</label>
		<description>Water and weathering have carved out branching networks of caverns beneath the sand and stone of the desert. With the searing hot sun unable to reach, the subterranean nature of this environment lends itself to cooler living for anything within.</description>
		<generatesNaturally>false</generatesNaturally>
		<canBuildBase>true</canBuildBase>
		<canAutoChoose>false</canAutoChoose>
		<modExtensions>
			<li Class="BiomesCore.DefModExtensions.BiomesMap">
				<isCavern>true</isCavern>
				<cavernShapes>
					<li>TunnelNetwork</li>
				</cavernShapes>
			</li>
		</modExtensions>
		<animalDensity>3.5</animalDensity>
		<plantDensity>1</plantDensity>
		<wildPlantsAreCavePlants>true</wildPlantsAreCavePlants>
		<wildPlantRegrowDays>27</wildPlantRegrowDays>
		<movementDifficulty>0.5</movementDifficulty>
		<forageability>0.5</forageability>
		<foragedFood>BMT_RawDulcis</foragedFood>
		<disableShadows>true</disableShadows>
		<disableSkyLighting>true</disableSkyLighting>
		<noAmbientWind>true</noAmbientWind>
		<constantOutdoorTemperature>28</constantOutdoorTemperature>
		<soundsAmbient>
			<li>BMT_Ambient_FungalForest</li>
		</soundsAmbient>
		<diseaseMtbDays>80</diseaseMtbDays>
		<diseases>
			<li>
				<diseaseInc>Disease_Flu</diseaseInc>
				<commonality>100</commonality>
			</li>
			<li>
				<diseaseInc>Disease_Plague</diseaseInc>
				<commonality>80</commonality>
			</li>
			<li>
				<diseaseInc>Disease_GutWorms</diseaseInc>
				<commonality>30</commonality>
			</li>
			<li>
				<diseaseInc>Disease_MuscleParasites</diseaseInc>
				<commonality>30</commonality>
			</li>
			<li>
				<diseaseInc>Disease_AnimalFlu</diseaseInc>
				<commonality>100</commonality>
			</li>
			<li>
				<diseaseInc>Disease_AnimalPlague</diseaseInc>
				<commonality>80</commonality>
			</li>
		</diseases>
		<terrainsByFertility>
			<li>
				<terrain>Sand</terrain>
				<min>-999</min>
				<max>999</max>
			</li>
		</terrainsByFertility>
		<terrainPatchMakers>
			<li>
				<perlinFrequency>0.04</perlinFrequency>
				<thresholds>
					<li>
						<terrain>Gravel</terrain>
						<min>0.35</min>
						<max>999</max>
					</li>
				</thresholds>
			</li>
		</terrainPatchMakers>
		<baseWeatherCommonalities>
			<BMT_Calm>100</BMT_Calm>
			<DryThunderstorm>0</DryThunderstorm>
			<FoggyRain>0</FoggyRain>
			<Rain>0</Rain>
			<RainyThunderstorm>0</RainyThunderstorm>
			<SnowGentle>0</SnowGentle>
			<SnowHard>0</SnowHard>
		</baseWeatherCommonalities>
		<wildPlants>
			<!-- ground cover -->
			<BMT_CavernMycelium>0.6</BMT_CavernMycelium>
			<!-- mid sized -->
			<BMT_Wheelshroom>0.2</BMT_Wheelshroom>
			<BMT_WatOrbs>0.1</BMT_WatOrbs>
			<BMT_BloomingCactus>0.2</BMT_BloomingCactus>
			<!-- trees -->
			<BMT_Dishcap>0.5</BMT_Dishcap>
			<!-- other harvestable -->
			<BMT_JuiceCactus>0.1</BMT_JuiceCactus>
			<BMT_DulcisPlant>0.05</BMT_DulcisPlant>
		</wildPlants>
		<wildAnimals>
			<!-- herbivores -->
			<BMT_Pillbug>0.1</BMT_Pillbug>
			<BMT_CaveCricket>0.2</BMT_CaveCricket>
			<BMT_MaceDrake>0.2</BMT_MaceDrake>
			<BMT_SandLeaper>0.4</BMT_SandLeaper>
			<BMT_ImperialToad>0.3</BMT_ImperialToad>
			<BMT_Stoneback>0.25</BMT_Stoneback>
			<BMT_PodWorm>0.01</BMT_PodWorm>
			<BMT_ChemSnail>0.025</BMT_ChemSnail>
			<!-- predators -->
			<BMT_Diggerpede>0.2</BMT_Diggerpede>
			<BMT_CactusCrab>0.1</BMT_CactusCrab>
			<BMT_CrestedDragon>0.1</BMT_CrestedDragon>
			<!-- omnivore -->
			<BMT_Xyrion>0.1</BMT_Xyrion>
		</wildAnimals>
		<pollutionWildAnimals/>
	</BiomeDef>

</Defs>
